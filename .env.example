# ============================================================
# CampusTrade — Environment Variables Template
# Copy this file to .env and fill in real values.
# ============================================================

# ---------- MongoDB ----------
# Local:
#   MONGODB_URI=mongodb://localhost:27017/campustrade
# Atlas:
#   MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=CampusTrade
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=CampusTrade
MONGODB_DB_NAME=campustrade

# ---------- JWT ----------
JWT_SECRET=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ---------- OpenAI ----------
OPENAI_API_KEY=sk-your-openai-key-here

# ---------- Email (SMTP) ----------
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ---------- Frontend ----------
FRONTEND_URL=http://localhost:5173

# ---------- Password Reset ----------
PASSWORD_RESET_EXPIRE_MINUTES=30

# ---------- App Settings ----------
ALLOWED_EMAIL_DOMAINS=@liverpool.ac.uk,@university.edu,@student.ac.uk
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
